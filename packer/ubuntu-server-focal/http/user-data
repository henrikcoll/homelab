#cloud-config
autoinstall:
  version: 1
  locale: en_US
  keyboard:
    layout: "no"
  ssh:
    install-server: true
    allow-pw: true
    disable_root: true
    ssh_quiet_keygen: true
    allow_public_ssh_keys: true
  packages:
    - qemu-guest-agent
    - sudo
  storage:
    layout:
      name: direct
    swap:
      size: 0
  user-data:
    package_upgrade: false
    timezone: Europe/Oslo
    users:
      - name: administrator
        groups: [adm, sudo]
        lock-passwd: false
        sudo: ALL=(ALL) NOPASSWD:ALL
        shell: /bin/bash
        passwd: $6$lPkFgE4hFrGfDfDe$S2wOfmzPWJe6m7OjUfhTl0E/d5FmGhMOYI3fSejaMPGANO4HnBj8qhOv8s.l5RmtycrDf0CUgjqae4T8ZcBpu.
